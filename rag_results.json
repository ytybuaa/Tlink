    {
      "question": "孔子如何看待学习与思考的关系？",
      "source_filter": "论语",
      "results": [
        {
          "id": "论语_0033",
          "text": "2.15子曰：“学而不思则罔，思而不学则殆。”",
          "source": "论语",
          "distance": 0.29638397693634033
        },
        {
          "id": "论语_0440",
          "text": "15.31子曰：“吾尝终日不食、终夜不寝以思，无益，不如学也。”",
          "source": "论语",
          "distance": 0.2742123603820801
        },
        {
          "id": "论语_0002",
          "text": "1.1子曰：“学而时习之，不亦说乎？有朋自远方来，不亦乐乎？人不知而不愠，不亦君子乎？”",
          "source": "论语",
          "distance": 0.35479462146759033
        },
        {
          "id": "论语_0213",
          "text": "8.17子曰：“学如不及，犹恐失之。”",
          "source": "论语",
          "distance": 0.36953794956207275
        },
        {
          "id": "论语_0111",
          "text": "5.14子路有闻，未之能行，唯恐有闻。",
          "source": "论语",
          "distance": 0.48720884323120117
        }
      ]
    },
    {
      "question": "孔子对'仁'的定义是什么？",
      "source_filter": "论语",
      "results": [
        {
          "id": "论语_0046",
          "text": "3.3子曰：“人而不仁，如礼何？人而不仁，如乐何？”",
          "source": "论语",
          "distance": 0.34318387508392334
        },
        {
          "id": "论语_0370",
          "text": "14.6子曰：“君子而不仁者有矣夫，未有小人而仁者也。”",
          "source": "论语",
          "distance": 0.3451382517814636
        },
        {
          "id": "论语_0071",
          "text": "4.1子曰：“里仁为美。择不处仁，焉得知？”",
          "source": "论语",
          "distance": 0.35114383697509766
        },
        {
          "id": "论语_0418",
          "text": "15.9子曰：“志士仁人无求生以害仁，有杀身以成仁。”",
          "source": "论语",
          "distance": 0.35241633653640747
        },
        {
          "id": "论语_0187",
          "text": "7.30子曰：“仁远乎哉？我欲仁，斯仁至矣。”",
          "source": "论语",
          "distance": 0.3559868335723877
        }
      ]
    },
