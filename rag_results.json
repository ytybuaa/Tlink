          "distance": 0.2707298994064331
        },
        {
          "id": "论语_0006",
          "text": "1.5子曰：“道千乘之国，敬事而信，节用而爱人，使民以时。”",
          "source": "论语",
          "distance": 0.2918505072593689
        },
        {
          "id": "论语_0083",
          "text": "4.13子曰：“能以礼让为国乎？何有？不能以礼让为国，如礼何？”",
          "source": "论语",
          "distance": 0.32541424036026
        },
        {
          "id": "论语_0018",
          "text": "为政第二",
          "source": "论语",
          "distance": 0.34632742404937744
        },
        {
          "id": "论语_0021",
          "text": "2.3子曰：“道之以政，齐之以刑，民免而无耻。道之以德，齐之以礼，有耻且格。”",
          "source": "论语",
          "distance": 0.3546321392059326
        }
      ]
    },
